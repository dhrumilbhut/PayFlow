# Application
NODE_ENV=development
API_PORT=3000
SERVICE_NAME=payflow-api

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payflow
DB_USER=payflow
DB_PASSWORD=payflow_secret
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_LOCK_TTL=30000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=payment.exchange
RABBITMQ_PROCESS_QUEUE=payment.process.queue
RABBITMQ_RETRY_QUEUE=payment.retry.queue
RABBITMQ_DLX_EXCHANGE=payment.dlx.exchange

# Gateway Simulator
GATEWAY_TIMEOUT_MS=5000
GATEWAY_SUCCESS_RATE=70
GATEWAY_FAILURE_RATE=20
GATEWAY_TIMEOUT_RATE=10
GATEWAY_WEBHOOK_URL=http://localhost:3000/webhook

# Circuit Breaker
CB_FAILURE_THRESHOLD=50
CB_VOLUME_THRESHOLD=5
CB_RESET_TIMEOUT=30000

# Retry
RETRY_BASE_DELAY_MS=2000
MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Logging
LOG_LEVEL=info
